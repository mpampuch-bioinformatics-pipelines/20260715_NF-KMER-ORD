nextflow_process {

    name "Test Process KMER_ORD_PROJECT"
    script "modules/local/kmer-ord/project/main.nf"
    process "KMER_ORD_PROJECT"
    tag "modules"
    tag "modules_local"
    tag "kmer-ord"

    // =========================================================================
    // REAL TESTS
    // =========================================================================

    test("Should run kmer-ord project on fasta input") {
        tag "slow"
        options "-dump-hashes"
        config "modules/local/kmer-ord/project/kmer-ord_project.test.config"

        when {
            process {
                """
                input[0] = [
                    [ id: '1percent' ],
                    file('${projectDir}/TESTS/TEST_DATA/63_Monoraphidiumcircinale.hifi_reads.subsampled.1percent.fasta', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assert process.success

            assert process.out.results_dir.size() == 1
            assert process.out.results_dir[0][0].id == '1percent'

            def outdir = file(process.out.results_dir[0][1])
            assert outdir.exists()
            assert outdir.isDirectory()

            assert process.out.versions.size() == 1
            assert path(process.out.versions[0]).readLines().any {
                it.contains("kmer-ord")
            }
        }
    }

    // =========================================================================
    // STUB TESTS
    // =========================================================================

    test("Should create stub results directory") {
        tag "stub"
        tag "fast"
        options "-stub-run -dump-hashes"

        when {
            process {
                """
                input[0] = [
                    [ id: '1percent' ],
                    file('${projectDir}/TESTS/TEST_DATA/63_Monoraphidiumcircinale.hifi_reads.subsampled.1percent.fasta', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assert process.success

            assert process.out.results_dir.size() == 1
            assert process.out.results_dir[0][0].id == '1percent'

            def outdir = file(process.out.results_dir[0][1])
            assert outdir.exists()
            assert outdir.isDirectory()
            assert file("${outdir}/stub.txt").exists()

            assert process.out.versions.size() == 1
        }
    }

}
