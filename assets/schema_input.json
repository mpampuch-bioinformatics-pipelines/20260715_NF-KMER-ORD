{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/nf-core/pipeline/master/assets/schema_input.json",
    "title": "nf-core/pipeline YAML samplesheet",
    "description": "Per-sample inputs and kmer-ord project/cluster/visualise settings.",
    "type": "array",
    "minItems": 1,
    "items": {
        "type": "object",
        "properties": {
            "id": {
                "type": "string",
                "pattern": "^\\S+$",
                "errorMessage": "Sample id must be provided and cannot contain spaces",
                "meta": "id"
            },
            "reads": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^\\S+\\.(fa|fasta|fna|fq|fastq)(\\.gz)?$",
                "errorMessage": "Reads file must be provided, cannot contain spaces, and must end in .fa, .fasta, .fna, .fq, .fastq, or gzipped variants"
            },
            "inject_tsv": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^\\S+\\.(tsv|txt)$",
                "errorMessage": "Optional inject file must be a .tsv/.txt path without spaces whose first column is 'sequence_id'"
            },
            "kmers": {
                "type": "array",
                "description": "K-mer sizes to run independently for this sample.",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                    "type": "integer",
                    "minimum": 1
                },
                "meta": "kmers"
            },
            "tiara": {
                "type": "boolean",
                "default": false,
                "meta": "tiara"
            },
            "dr": {
                "type": "array",
                "description": "Dimensionality-reduction methods to run (shared by project and cluster).",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                    "type": "string",
                    "enum": [
                        "umap",
                        "tsne",
                        "trimap",
                        "pacmap",
                        "localmap",
                        "pca",
                        "sparse_pca",
                        "kernel_pca",
                        "lle"
                    ]
                },
                "meta": "dr"
            },
            "scale": {
                "type": "string",
                "default": "auto",
                "meta": "scale"
            },
            "norm": {
                "type": "string",
                "default": "clr",
                "meta": "norm"
            },
            "dims": {
                "type": "integer",
                "description": "Low-dimensional (2D/3D) projection size used by kmer-ord project.",
                "minimum": 1,
                "default": 2,
                "meta": "dims"
            },
            "cluster_dims": {
                "type": "integer",
                "description": "High-dimensional embedding size used by kmer-ord cluster.",
                "minimum": 1,
                "default": 15,
                "meta": "cluster_dims"
            },
            "cluster": {
                "type": "array",
                "description": "Clustering methods to run in kmer-ord cluster.",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                    "type": "string",
                    "enum": ["leiden", "hdbscan", "dbscan"]
                },
                "default": ["hdbscan"],
                "meta": "cluster"
            },
            "leiden_sweep": {
                "type": "boolean",
                "default": false,
                "meta": "leiden_sweep"
            },
            "hdbscan_sweep": {
                "type": "boolean",
                "default": false,
                "meta": "hdbscan_sweep"
            },
            "dbscan_sweep": {
                "type": "boolean",
                "default": false,
                "meta": "dbscan_sweep"
            },
            "pca_pre": {
                "type": "boolean",
                "default": false,
                "meta": "pca_pre"
            },
            "keep_pcs": {
                "type": ["integer", "null"],
                "minimum": 1,
                "default": null,
                "meta": "keep_pcs"
            },
            "keep_variance": {
                "type": ["number", "null"],
                "exclusiveMinimum": 0,
                "maximum": 1,
                "default": null,
                "meta": "keep_variance"
            },
            "screen_params": {
                "type": "boolean",
                "default": false,
                "meta": "screen_params"
            },
            "max_categories": {
                "type": "integer",
                "description": "Max number of categories for categorical feature plots in kmer-ord visualise.",
                "minimum": 1,
                "default": 10,
                "meta": "max_categories"
            },
            "embeddings": {
                "type": "boolean",
                "description": "Generate embedding plots in kmer-ord visualise.",
                "default": true,
                "meta": "embeddings"
            },
            "embedding_mode": {
                "type": "string",
                "description": "Embedding plot mode for kmer-ord visualise.",
                "enum": ["density", "categorical", "continuous", "all"],
                "default": "all",
                "meta": "embedding_mode"
            },
            "features": {
                "type": "boolean",
                "description": "Generate feature plots in kmer-ord visualise.",
                "default": true,
                "meta": "features"
            },
            "threads": {
                "type": ["integer", "null"],
                "minimum": 1,
                "default": null,
                "meta": "threads"
            }
        },
        "required": ["id", "reads", "kmers", "dr"]
    },
    "uniqueEntries": ["id"]
}
